# DeepLex backend environment

# Local development with SQLite. This creates backend/deeplex_local.db when run from backend/.
APP_ENV=development
DEBUG=true
DATABASE_URL=sqlite:///./deeplex_local.db

# PostgreSQL option for Docker, production, or shared environments:
# APP_ENV=production
# DEBUG=false
# DATABASE_URL=postgresql://postgres:postgres@db:5432/deeplex

SECRET_KEY=replace-with-a-long-random-secret-key-32chars-min
REFRESH_SECRET_KEY=replace-with-a-different-long-random-refresh-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ALLOWED_HOSTS=localhost,127.0.0.1,testserver
RUN_MIGRATIONS_ON_START=1
MYMEMORY_DE_EMAIL=you@example.com
